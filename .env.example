# Ironscales credentials (required in env mode; injected by gateway in gateway mode)
IRONSCALES_API_KEY=your-api-key-here
IRONSCALES_COMPANY_ID=your-company-id-here

# Transport: stdio (default) or http
MCP_TRANSPORT=http
MCP_HTTP_PORT=8080
MCP_HTTP_HOST=0.0.0.0

# Auth mode: env (read from env vars) or gateway (injected via headers)
AUTH_MODE=env

# Log level: debug, info, warn, error
LOG_LEVEL=info
