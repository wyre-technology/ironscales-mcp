{
  "name": "@wyre-technology/ironscales-mcp",
  "version": "1.0.1",
  "description": "MCP server for Ironscales — phishing incident management, email classification, and remediation",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "mcpb:pack": "npm run build && npm install --production && mcpb pack",
    "cf:deploy": "npm run build && wrangler deploy",
    "cf:dev": "npm run build && wrangler dev"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "msw": "^2.14.6",
    "semantic-release": "^25.0.5",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wyre-technology/ironscales-mcp.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "restricted"
  }
}
